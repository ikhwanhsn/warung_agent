# From @BotFather
TELEGRAM_BOT_TOKEN=

# Jatevo Private AI (OpenAI-compatible). Required: all user-visible bot text goes through Jatevo.
# Docs: https://jatevo.ai/private-ai/api
JATEVO_API_KEY=
# Base URL (default: https://inference.jatevo.id/v1)
# JATEVO_API_BASE=https://inference.jatevo.id/v1
# Model id (default: glm-4.7). Examples: deepseek-v3.2, kimi-k2.5
# JATEVO_MODEL=glm-4.7

# Optional: restrict bot to one chat (numeric id). Leave empty to allow any user.
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# Optional: path to QRIS demo image (same asset as landing public/images/qris.webp). If unset, bot uses bot-telegram/assets/qris.webp, then landing path, then a generated demo QR PNG.
# TELEGRAM_QRIS_IMAGE_PATH=D:\warung_agent\landing\public\images\qris.webp
