# Backend base URL (no trailing slash). Default in code: http://localhost:3000
VITE_API_URL=http://localhost:3000

# Privy (required for wallet + email login) — from https://dashboard.privy.io
VITE_PRIVY_APP_ID=
# Optional, for some Privy setups
# VITE_PRIVY_CLIENT_ID=

# Solana RPC (optional; default Ankr public in WalletContext)
# VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: trading experiment page cron
# VITE_TRADING_EXPERIMENT_CRON_SECRET=
